    given-names: Pierre-Nicholas
    # orcid: "https://orcid.org/0000-0000-0000-0000"
keywords:
  - DMRG
  - tensor networks
  - ITensor
  - quantum phase transition
  - geometric frustration
  - ferroelectricity
  - antiferroelectricity
  - endofullerene
  - dipolar rotors
  - confined water
